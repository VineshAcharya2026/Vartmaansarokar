# Server Configuration
PORT=5174
NODE_ENV=development

# Security
JWT_SECRET=your-super-secure-jwt-secret-here-change-this-in-production

# File Upload
MAX_UPLOAD_SIZE_BYTES=5242880

# Frontend Configuration (exposed to client)
VITE_API_BASE_URL=http://localhost:5174
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
VITE_STAFF_PASSWORD=PassworD@2026
VITE_SUPER_ADMIN_EMAIL=superadmin@vartmaansarokar.com
VITE_ADMIN_EMAIL=admin@vartmaansarokar.com
VITE_EDITOR_EMAIL=editor@vartmaansarokar.com

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=your-google-client-id-here

# CORS (local frontend + optional additional local origins)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google reCAPTCHA (v2 checkbox or v3 — server verifies with secret)
RECAPTCHA_SECRET_KEY=

# Resend transactional email (optional — without this, emails are skipped except dev console)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Admin inbox for new subscription notifications
ADMIN_EMAIL=admin@vartmaansarokar.com

# Vite client: reCAPTCHA site key + public payment display (shown in subscription popup)
VITE_RECAPTCHA_SITE_KEY=
VITE_PUBLIC_UPI_ID=vartmaan@upi
VITE_PUBLIC_BANK_NAME=
VITE_PUBLIC_BANK_ACCOUNT=
VITE_PUBLIC_BANK_IFSC=
