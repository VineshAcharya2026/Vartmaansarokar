# Do not add real values here. Use .env locally and GitHub Secrets for CI.

# Server Configuration
PORT=5174
NODE_ENV=development

# Security
JWT_SECRET=your-super-secure-jwt-secret-here-change-this-in-production

# File Upload
MAX_UPLOAD_SIZE_BYTES=5242880

# Frontend (Vite — VITE_* is exposed to the client; never put secrets in VITE_*)
# Dev: local API. Production build: set in .env.production or CI (see also default in utils/app.ts).
VITE_API_BASE_URL=http://localhost:5174
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
# Optional (local dev, npm run dev): prefill /staff-login — must match Worker: wrangler secret put STAFF_PASSWORD -c wrangler.worker.toml
# VITE_DEV_STAFF_DEMO=your-staff-password
VITE_SUPER_ADMIN_EMAIL=superadmin@vartmaansarokar.com
VITE_ADMIN_EMAIL=admin@vartmaansarokar.com
VITE_EDITOR_EMAIL=editor@vartmaansarokar.com

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=your-google-client-id-here

# CORS (for production)
ALLOWED_ORIGINS=https://vartmaansarokaar.com,https://www.vartmaansarokar.com,https://main.vartmaan-sarokar-pages.pages.dev

# Cloudflare (Node scripts via config/env.js — wrangler/CI use dashboard secrets or GITHUB_SECRETS)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
D1_DATABASE_ID=your_database_id
