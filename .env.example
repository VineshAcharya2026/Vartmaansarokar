# Server Configuration
PORT=5174
NODE_ENV=development

# Security
JWT_SECRET=your-super-secure-jwt-secret-here-change-this-in-production

# File Upload
MAX_UPLOAD_SIZE_BYTES=5242880

# Frontend Configuration (exposed to client — never put real staff passwords here)
VITE_API_BASE_URL=http://localhost:5174
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
# Optional: local dev only (npm run dev). Prefills staff login on /staff-login; must match Worker wrangler secret STAFF_PASSWORD
# VITE_DEV_STAFF_DEMO=your-local-test-password
VITE_SUPER_ADMIN_EMAIL=superadmin@vartmaansarokar.com
VITE_ADMIN_EMAIL=admin@vartmaansarokar.com
VITE_EDITOR_EMAIL=editor@vartmaansarokar.com

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=your-google-client-id-here

# CORS (for production)
ALLOWED_ORIGINS=https://vartmaansarokaar.com,https://www.vartmaansarokaar.com,https://main.vartmaan-sarokar-pages.pages.dev

# Cloudflare / Wrangler (local CLI & tools — optional; not used by the Vite app directly)
# GitHub Actions: add secret CLOUDFLARE_API_TOKEN in the repo; CI does not read .env
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
D1_DATABASE_ID=9cc9608f-c17b-43f4-aa8c-4fc3306f02a4
