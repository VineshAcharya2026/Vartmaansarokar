{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "noEmit": true
  },
  "include": [
    "App.tsx",
    "AppContext.tsx",
    "constants.ts",
    "index.tsx",
    "i18n.js",
    "types.ts",
    "vite.config.ts",
    "vite-env.d.ts",
    "components/**/*",
    "pages/**/*",
    "utils/**/*"
  ],
  "exclude": ["dist", "node_modules", "server"]
}
