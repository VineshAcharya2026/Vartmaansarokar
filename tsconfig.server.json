{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-server",
    "rootDir": ".",
    "types": ["node", "./worker-configuration.d.ts"],
    "strict": true,
    "noEmit": false
  },
  "include": [
    "server/index.new.ts",
    "server/store.ts",
    "server/controllers/**/*.ts",
    "server/middlewares/**/*.ts",
    "server/routes/**/*.ts",
    "server/services/**/*.ts",
    "server/utils/**/*.ts",
    "scripts/**/*.ts",
    "constants.ts",
    "types.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": ["server/index.ts", "server/workers-entry.ts", "server/oauth-worker.ts", "server/d1-store.ts", "server/jwt-crypto.ts"]
}
