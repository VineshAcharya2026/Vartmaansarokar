# Cloudflare Pages: avoid stale index.html (users stuck on old JS) while keeping hashed assets cacheable.
# https://developers.cloudflare.com/pages/configuration/headers/
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML shell should revalidate so new deploys are picked up quickly.
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
