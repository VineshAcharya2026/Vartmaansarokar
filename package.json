{
  "name": "vartmaan-sarokaar",
  "private": true,
  "version": "0.0.11",
  "type": "module",
  "homepage": "https://vineshacharya2026.github.io/VartmaanSarokar",
  "scripts": {
    "dev": "vite",
    "server:dev": "wrangler dev -c wrangler.worker.toml",
    "dev:workers": "wrangler dev -c wrangler.worker.toml",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "build": "npm run typecheck && vite build",
    "build:workers": "wrangler types -c wrangler.worker.toml && tsc -p tsconfig.server.json --noEmit",
    "preview": "vite preview",
    "seed": "tsx ./scripts/seed-cloudflare-content.ts",
    "env:validate": "node -e \"import('./config/env.js').then(m=>{m.getCloudflareEnv();console.log('Cloudflare env OK')})\"",
    "seed:content": "tsx ./scripts/seed-cloudflare-content.ts",
    "seed:articles": "node ./scripts/seedArticles.js",
    "seed:articles:api": "node ./scripts/seed-articles-via-api.mjs",
    "migrate:d1": "tsx ./migrations/migrate-to-d1.ts",
    "deploy": "deploy.bat",
    "deploy:workers": "wrangler deploy -c wrangler.worker.toml",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name=vartmaan-sarokar-pages",
    "deploy:cloudflare": "npm run deploy:workers && npm run deploy:pages",
    "deploy:gh": "gh-pages -d dist",
    "db:schema": "wrangler d1 execute vartmaansarokar-db --file=schema.sql -c wrangler.worker.toml",
    "db:create": "wrangler d1 create vartmaansarokar-db",
    "r2:create": "wrangler r2 bucket create vartmaan-media",
    "secrets:set": "echo Run: wrangler secret put JWT_SECRET -c wrangler.worker.toml and same for STAFF_PASSWORD, GOOGLE_CLIENT_ID",
    "production-check": "echo See DEPLOYMENT.md for complete deployment instructions"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.3.1",
    "gsap": "^3.13.0",
    "hono": "^4.12.12",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.1",
    "react-pageflip": "^2.0.3",
    "react-router-dom": "^7.11.0",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.81.1"
  }
}
